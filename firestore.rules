rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Skor: scores/{gameId}/leaderboard/{userId}
    match /scores/{gameId}/leaderboard/{userId} {
      // Herkes okuyabilir
      allow read: if true;

      // Giriş yapmış kullanıcı sadece kendi belgesini oluşturabilir/güncelleyebilir
      allow create, update: if request.auth != null
                   && userId == request.auth.uid
                   && request.resource.data.score is number
                   && request.resource.data.score >= 0
                   && request.resource.data.score <= 9999999
                   && request.resource.data.keys().hasAll(['score', 'name', 'uid', 'gameId', 'updatedAt'])
                   && request.resource.data.keys().hasOnly(['score', 'name', 'uid', 'gameId', 'updatedAt']);
    }
  }
}

rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Skor: scores/{gameId}/leaderboard/{userId}
    match /scores/{gameId}/leaderboard/{userId} {
      // Herkes okuyabilir
      allow read: if true;

      // Giriş yapmış kullanıcı sadece kendi belgesini oluşturabilir/güncelleyebilir
      allow create, update: if request.auth != null
                   && userId == request.auth.uid
                   && request.resource.data.uid == request.auth.uid
                   && request.resource.data.gameId == gameId
                   && gameId.size() <= 40
                   && request.resource.data.score is number
                   && request.resource.data.score >= 0
                   && request.resource.data.score <= 9999999
                   && request.resource.data.name is string
                   && request.resource.data.name.size() >= 1
                   && request.resource.data.name.size() <= 30
                   && request.resource.data.date is string
                   && request.resource.data.date.size() <= 40
                   && request.resource.data.date.matches('^[0-9]{4}-[0-9]{2}-[0-9]{2}T.*Z$')
                   && request.resource.data.updatedAt == request.time
                   && request.resource.data.keys().hasAll(['score', 'name', 'uid', 'gameId', 'date', 'updatedAt'])
                   && request.resource.data.keys().hasOnly(['score', 'name', 'uid', 'gameId', 'date', 'updatedAt']);
    }
  }
}

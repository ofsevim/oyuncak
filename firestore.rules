rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Skor: scores/{gameId}/leaderboard/{userId}
    match /scores/{gameId}/leaderboard/{userId} {
      // Herkes okuyabilir
      allow read: if true;

      // Giriş yapmış kullanıcı sadece kendi belgesini yazabilir
      allow write: if request.auth != null
                   && userId == request.auth.uid
                   && request.resource.data.score is number
                   && request.resource.data.score >= 0;
    }
  }
}
